# HADES environment template
#
# This is a reference for the variables HADES writes to ~/.hades/.env during install.
# You do NOT normally edit this file by hand; the installer generates ~/.hades/.env for you.
# Use this to understand what each setting does, or to pre-seed a non-interactive install.
#
# Never commit a real .env with filled-in keys. Keep secrets out of version control.

# --- Core runtime ---

# Which provider HADES talks to.
# One of: openrouter | anthropic | openai | google | deepseek | custom
MODEL_PROVIDER=openrouter

# Model identifier passed to the provider.
MODEL_NAME=deepseek/deepseek-v4-flash:free

# Host/API port the local server binds to (127.0.0.1 only).
API_SERVER_PORT=8642

# Bearer token for the local API server. The installer generates a random one.
# Leave blank to let the installer generate it; never reuse a provider key here.
API_SERVER_KEY=

# Build-time: install Chromium/Playwright browser tooling (1) or not (0).
# Off by default. Adds ~450 MB. Requires `hades update` to take effect.
INSTALL_BROWSER=0

# Pinned upstream Hermes Agent release tag.
HERMES_VERSION=v2026.5.29

# Docker base image variant used at build time.
PYTHON_VERSION=3.12-slim-bookworm

# Allow any API key to act as any user. Default true for backward compatibility.
GATEWAY_ALLOW_ALL_USERS=true

# --- Provider keys (fill only the one matching MODEL_PROVIDER) ---

OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Custom OpenAI-compatible endpoint
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
